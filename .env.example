# URL вашого бекенду, який приймає POST multipart/form-data (поле "file")
# і повертає JSON у форматі src/data/protocol.json.
# Локально (паралельний Node-сервіс у ../protocol-parse-service): npm start → порт 3001
VITE_PROTOCOL_PARSE_URL=http://localhost:3001/parse-protocol

# Необов'язково. Увага: змінні VITE_* потрапляють у клієнтський бандл — не використовуйте
# справжній продакшен-секрет тут. Краще: бекенд сам додає Authorization або перевіряє сесію.
VITE_PROTOCOL_PARSE_API_KEY=

# Таймаут очікування відповіді парсера (мс). OpenAI на великому PDF може йти 1–3 хв.
# VITE_PROTOCOL_PARSE_TIMEOUT_MS=240000
